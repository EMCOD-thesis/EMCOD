 105:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****         /* Yes, valid thread entry, proceed...  */
 106:../Middlewares/threadx/common/src/tx_timer_thread_entry.c **** 
 107:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****         /* Now go into an infinite loop to process timer expirations.  */
 108:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****         while (TX_LOOP_FOREVER)
 109:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****         {
 110:../Middlewares/threadx/common/src/tx_timer_thread_entry.c **** 
 111:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             /* First, move the current list pointer and clear the timer
 112:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****                expired value.  This allows the interrupt handling portion
 113:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****                to continue looking for timer expirations.  */
 114:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             TX_DISABLE
 115:../Middlewares/threadx/common/src/tx_timer_thread_entry.c **** 
 116:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             /* Save the current timer expiration list pointer.  */
 117:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             expired_timers =  *_tx_timer_current_ptr;
 118:../Middlewares/threadx/common/src/tx_timer_thread_entry.c **** 
 119:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             /* Modify the head pointer in the first timer in the list, if there
 120:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****                is one!  */
 121:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             if (expired_timers != TX_NULL)
 122:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             {
 123:../Middlewares/threadx/common/src/tx_timer_thread_entry.c **** 
 124:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****                 expired_timers -> tx_timer_internal_list_head =  &expired_timers;
 125:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             }
 126:../Middlewares/threadx/common/src/tx_timer_thread_entry.c **** 
 127:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             /* Set the current list pointer to NULL.  */
 128:../Middlewares/threadx/common/src/tx_timer_thread_entry.c ****             *_tx_timer_current_ptr =  TX_NULL;
