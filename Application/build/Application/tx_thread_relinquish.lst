  48:../Middlewares/threadx/common/src/tx_thread_relinquish.c **** /*    This function moves the currently executing thread to the end of    */
  49:../Middlewares/threadx/common/src/tx_thread_relinquish.c **** /*    the list of threads ready at the same priority. If no other threads */
  50:../Middlewares/threadx/common/src/tx_thread_relinquish.c **** /*    of the same or higher priority are ready, this function simply      */
  51:../Middlewares/threadx/common/src/tx_thread_relinquish.c **** /*    returns.                                                            */
