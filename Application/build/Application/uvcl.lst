  71:../Middlewares/screenl/uvcl/Src/uvcl.c **** static void UVCL_FillSentData(UVCL_Ctx_t *p_ctx, UVCL_OnFlyCtx_t *on_fly_ctx, uint8_t *p_frame, int
  72:../Middlewares/screenl/uvcl/Src/uvcl.c ****                              int packet_size)
  73:../Middlewares/screenl/uvcl/Src/uvcl.c **** {
  74:../Middlewares/screenl/uvcl/Src/uvcl.c ****   on_fly_ctx->packet_nb = (fsize + packet_size - 1) / (packet_size - 2);
  75:../Middlewares/screenl/uvcl/Src/uvcl.c ****   on_fly_ctx->last_packet_size = fsize % (packet_size - 2);
  76:../Middlewares/screenl/uvcl/Src/uvcl.c ****   if (!on_fly_ctx->last_packet_size)
  77:../Middlewares/screenl/uvcl/Src/uvcl.c ****   {
  78:../Middlewares/screenl/uvcl/Src/uvcl.c ****     on_fly_ctx->packet_nb--;
  79:../Middlewares/screenl/uvcl/Src/uvcl.c ****     on_fly_ctx->last_packet_size = packet_size - 2;
  80:../Middlewares/screenl/uvcl/Src/uvcl.c ****   }
  81:../Middlewares/screenl/uvcl/Src/uvcl.c ****   on_fly_ctx->p_frame = p_frame;
  82:../Middlewares/screenl/uvcl/Src/uvcl.c ****   on_fly_ctx->cursor = p_frame;
  83:../Middlewares/screenl/uvcl/Src/uvcl.c ****   p_ctx->packet[1] ^= 1;
  84:../Middlewares/screenl/uvcl/Src/uvcl.c **** 
  85:../Middlewares/screenl/uvcl/Src/uvcl.c ****   p_ctx->is_starting = 0;
  86:../Middlewares/screenl/uvcl/Src/uvcl.c ****   p_ctx->frame_start = HAL_GetTick();
  87:../Middlewares/screenl/uvcl/Src/uvcl.c **** }
