 102:../Middlewares/screenl/uvcl/Src/uvcl.c **** static int UVCL_handle_set_itf_setup_request(UVCL_Ctx_t *p_ctx, UVCL_SetupReq_t *req)
 103:../Middlewares/screenl/uvcl/Src/uvcl.c **** {
 104:../Middlewares/screenl/uvcl/Src/uvcl.c ****   uint16_t wIndex = req->wIndex;
 105:../Middlewares/screenl/uvcl/Src/uvcl.c ****   uint16_t wValue = req->wValue;
 106:../Middlewares/screenl/uvcl/Src/uvcl.c ****   int ret;
 107:../Middlewares/screenl/uvcl/Src/uvcl.c **** 
 108:../Middlewares/screenl/uvcl/Src/uvcl.c ****   /* Only handle control on vs itf */
 109:../Middlewares/screenl/uvcl/Src/uvcl.c ****   if (wIndex != 1)
 110:../Middlewares/screenl/uvcl/Src/uvcl.c ****     return -1;
 111:../Middlewares/screenl/uvcl/Src/uvcl.c **** 
 112:../Middlewares/screenl/uvcl/Src/uvcl.c ****   switch (wValue) {
 113:../Middlewares/screenl/uvcl/Src/uvcl.c ****   case 0:
 114:../Middlewares/screenl/uvcl/Src/uvcl.c ****     /* set alternate itf to zero => stop streaming */
 115:../Middlewares/screenl/uvcl/Src/uvcl.c ****     ret = req->stop_streaming(req->ctx);
 116:../Middlewares/screenl/uvcl/Src/uvcl.c ****     break;
 117:../Middlewares/screenl/uvcl/Src/uvcl.c ****   case 1:
 118:../Middlewares/screenl/uvcl/Src/uvcl.c ****     /* set alternate itf to one => start streaming */
 119:../Middlewares/screenl/uvcl/Src/uvcl.c ****     ret = req->start_streaming(req->ctx);
 120:../Middlewares/screenl/uvcl/Src/uvcl.c ****     break;
 121:../Middlewares/screenl/uvcl/Src/uvcl.c ****   default:
 122:../Middlewares/screenl/uvcl/Src/uvcl.c ****     assert(0);
 123:../Middlewares/screenl/uvcl/Src/uvcl.c ****     return -1;
 124:../Middlewares/screenl/uvcl/Src/uvcl.c ****   }
 125:../Middlewares/screenl/uvcl/Src/uvcl.c **** 
 126:../Middlewares/screenl/uvcl/Src/uvcl.c ****   return ret;
ARM GAS  /tmp/ccbJxyKS.s 			page 4


 127:../Middlewares/screenl/uvcl/Src/uvcl.c **** }
