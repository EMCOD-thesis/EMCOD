  24:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h **** /*!
  25:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * @defgroup datatypes_internal Internal Datatypes
  26:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * @brief Data structures used internally to implement neural networks
  27:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  *
  28:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * The layers are defined as structs; a generic layer type defines the basic
  29:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * layer parameters and type-specific parameters are handled by specializations
  30:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * implemented as a C union. The layers keep also a pointer to the parent
  31:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * network and the next layer in the network.
  32:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * The input, output and parameters are tensor with an hard-coded maximum
  33:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * dimension of 4. Tensors are floating point arrays with a notion of size.
  34:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * The network is a linked list of layers, and thus it stores only the pointer
  35:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * to the first layer.
  36:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  */
  37:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h **** 
  38:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h **** /*!
  39:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * @section Offsets
  40:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * @ingroup datatypes_internal
  41:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * Macros to handle (byte) stride addressing on tensors. The `AI_PTR` macro
  42:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * is used to always cast a pointer to byte array. The macros `AI_OFFSET_X` are
  43:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * used to compute (byte) offsets of respectively adjacents row elements, col
  44:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * elements, channel elements and `channel_in` elements.
  45:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  * @{
ARM GAS  /tmp/cc99hmNC.s 			page 114


  46:../Middlewares/stedgeai-lib/Inc/ai_datatypes_internal.h ****  */
