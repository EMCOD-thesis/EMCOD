 218:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #define TX_TRACE_TIME_SOURCE                    *((volatile ULONG *) 0xE0001004)
 219:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #endif
 220:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #else
 221:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** ULONG   _tx_misra_time_stamp_get(VOID);
 222:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #define TX_TRACE_TIME_SOURCE                    _tx_misra_time_stamp_get()
 223:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #endif
 224:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** 
 225:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #ifndef TX_TRACE_TIME_MASK
