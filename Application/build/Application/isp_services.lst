 153:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c **** static void To_Shift_Multiplier(uint32_t Factor, uint8_t *pShift, uint8_t *pMultiplier)
 154:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c **** {
 155:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   /* Convert Factor (Unit = 100000000 for "x1.0") to Multiplier (where 128 means "x1.0") */
 156:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   uint64_t Val = Factor;
 157:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   Val = (Val * 128) / ISP_GAIN_PRECISION_FACTOR;
 158:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c **** 
 159:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   /* Get Shift + Multiplier where Multiplier < 256 */
 160:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   *pShift = 0;
 161:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   while (Val >= 256)
 162:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   {
 163:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****     Val /= 2;
 164:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****     (*pShift)++;
 165:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   }
 166:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c **** 
 167:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c ****   *pMultiplier = (uint8_t)Val;
 168:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_services.c **** }
