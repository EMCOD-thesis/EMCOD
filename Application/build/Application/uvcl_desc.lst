  34:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** struct buffer_allocator {
  35:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   void *buffer;
  36:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   int buffer_size;
  37:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   void *current;
  38:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   void *limit;
  39:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** };
  40:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  41:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** static int ba_init(struct buffer_allocator *ba)
  42:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** {
  43:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   if (!ba->buffer)
  44:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     return -1;
  45:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   if ((uintptr_t)ba->buffer & 0x3)
  46:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     return -1;
  47:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   if (ba->buffer <= 0)
  48:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     return  -1;
  49:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  50:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   ba->current = ba->buffer;
  51:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   ba->limit = (uint8_t *)ba->buffer + ba->buffer_size;
  52:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  53:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   return 0;
  54:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** }
  55:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  56:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** static void *ba_alloc(struct buffer_allocator *ba, size_t size)
  57:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** {
  58:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   void *res = ba->current;
  59:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  60:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   if (size <= 0)
  61:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     return NULL;
  62:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  63:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   if ((uint8_t *)ba->current + size >= (uint8_t *)ba->limit)
  64:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     return NULL;
  65:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  66:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   size = (size + 3) & ~0x3;
  67:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   ba->current = (uint8_t *)ba->buffer + size;
  68:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  69:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   return res;
  70:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** }
