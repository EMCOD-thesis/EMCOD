 124:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** static int UVCL_get_string_desc(void *p_dst, int dst_len, char *name)
 125:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** {
 126:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   int desc_len = 2 + strlen(name) * 2;
 127:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   uint8_t *dst = p_dst;
 128:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
 129:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   if (dst_len < desc_len)
 130:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     return -1;
 131:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
 132:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   *dst++ = desc_len; /* bLength = desc_len */
 133:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   *dst++ = 0x03; /* string descriptor */
 134:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
 135:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   while (*name) {
 136:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     *dst++ = *name++;
 137:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     *dst++ = 0;
 138:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   }
 139:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
 140:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   return dst_len;
 141:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** }
