  72:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** static int compute_min_fps(int *fps, int fps_nb)
  73:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** {
  74:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   int min_fps = fps[0];
  75:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   int i;
  76:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  77:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   for (i = 1; i <fps_nb; i++)
  78:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****     min_fps = MIN(min_fps, fps[i]);
  79:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** 
  80:../Middlewares/screenl/uvcl/Src/uvcl_desc.c ****   return min_fps;
  81:../Middlewares/screenl/uvcl/Src/uvcl_desc.c **** }
