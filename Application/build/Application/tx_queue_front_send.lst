 273:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #else
 274:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** /* ThreadX in only one zone. */
 275:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #define TX_THREAD_EXTENSION_2           VOID    *tx_thread_iar_tls_pointer;
 276:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #endif
 277:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** 
