 175:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton.c ****   t = ATON_CLKCTRL_CTRL_SET_CLR(t, 1);
 176:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton.c ****   ATON_CLKCTRL_CTRL_SET(0, t);
 177:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton.c **** 
 178:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton.c ****   /* Enable all ATON clocks */
