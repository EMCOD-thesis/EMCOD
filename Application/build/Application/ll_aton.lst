 180:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton.c ****   ATON_CLKCTRL_AGATES0_SET(0, 0xffffffff);
 181:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton.c ****   ATON_CLKCTRL_AGATES1_SET(0, 0xffffffff);
