  47:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    This function retrieves performance information from the specified  */
  48:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    thread.                                                             */
  49:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                                                        */
  50:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*  INPUT                                                                 */
  51:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                                                        */
  52:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    thread_ptr                        Pointer to thread control block   */
  53:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    resumptions                       Destination for number of times   */
  54:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread was resumed              */
  55:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    suspensions                       Destination for number of times   */
  56:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread was suspended            */
  57:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    solicited_preemptions             Destination for number of times   */
  58:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread called another service   */
  59:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        that resulted in preemption     */
  60:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    interrupt_preemptions             Destination for number of times   */
  61:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread was preempted by another */
  62:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread made ready in Interrupt  */
  63:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        Service Routine (ISR)           */
  64:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    priority_inversions               Destination for number of times   */
  65:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        a priority inversion was        */
  66:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        detected for this thread        */
  67:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    time_slices                       Destination for number of times   */
  68:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread was time-sliced          */
  69:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    relinquishes                      Destination for number of thread  */
  70:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        relinquishes                    */
  71:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    timeouts                          Destination for number of timeouts*/
  72:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        for thread                      */
  73:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    wait_aborts                       Destination for number of wait    */
  74:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        aborts for thread               */
  75:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*    last_preempted_by                 Destination for pointer of the    */
  76:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread that last preempted this */
  77:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                        thread                          */
  78:../Middlewares/threadx/common/src/tx_thread_performance_info_get.c **** /*                                                                        */
