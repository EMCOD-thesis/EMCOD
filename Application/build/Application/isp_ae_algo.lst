 147:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   uint32_t global_exposure;
 148:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** 
 149:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   /* Compute adjusted_gain and exposure in any case even if antiflicker is disabled
 150:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****    * This way, in case there is no light condition change, previous adjustment for antiflicker
 151:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****    * will be removed */
 152:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** 
 153:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   global_exposure = (uint32_t)(exposure * pow(10, (float)gain / (20 * 1000)));
 154:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   if (global_exposure < pSensorInfo->exposure_max)
 155:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   {
 156:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *original_gain = 0;
 157:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *original_exposure = global_exposure;
 158:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     /* Fix rounding error when close to max value */
 159:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     if (*original_exposure > 0.98 * pSensorInfo->exposure_max)
 160:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     {
 161:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****       *original_exposure = pSensorInfo->exposure_max;
 162:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     }
 163:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   }
 164:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   else
 165:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   {
 166:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     /* Set exposure to max, and compute the compensation gain */
 167:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *original_exposure = pSensorInfo->exposure_max;
 168:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     /* Increase the gain accordingly */
 169:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     compensation_gain = (float)global_exposure / (float)*original_exposure;
 170:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *original_gain = (uint32_t)(20 * 1000 * log10(compensation_gain));
 171:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   }
 172:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** }
