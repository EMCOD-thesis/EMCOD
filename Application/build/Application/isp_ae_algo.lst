  75:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** /**
  76:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   * @brief  isp_ae_compute_antiflcker
  77:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   *         ONLY USEFUL WHEN WHEN ANTI-FLICKER IS ACTIVATED
  78:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   *         Otherwise exposure time and gain are unchanged
  79:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   *         This function will compute an exposure time that eliminates the flickering effect
  80:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   *         and compensates with gain to still achieve the desired brightness
  81:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   * @param  gain             : current sensor gain value (mdB)
  82:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   * @param  exposure         : current sensor exposure time value (us)
  83:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   * @param  adjusted_gain    : pointer to the new exposure time value (us)
  84:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   * @param  adjusted_exposure: pointer to the new sensor gain value (mdB)
  85:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   * @retval None
  86:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   */
  87:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** static void isp_ae_compute_antiflcker(uint32_t gain, uint32_t exposure,
