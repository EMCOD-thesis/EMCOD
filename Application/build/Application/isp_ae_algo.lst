  89:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** {
ARM GAS  /tmp/ccibXm08.s 			page 4


  90:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   /* Get equivalent gain/exposure where exposure is a multiple of the flickering period */
  91:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   float compensation_gain;
  92:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   uint32_t compensation_gain_mdb, compat_period_us;
  93:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   uint32_t up_equiv_exposure;
  94:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** 
  95:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   if (IQParamConfig->AECAlgo.antiFlickerFreq == 0)
  96:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   {
  97:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *adjusted_gain = gain;
  98:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *adjusted_exposure = exposure;
  99:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     return;
 100:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   }
 101:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** 
 102:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   compat_period_us = 1000U * 1000U / (2U * IQParamConfig->AECAlgo.antiFlickerFreq);
 103:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   up_equiv_exposure = (1 + exposure / compat_period_us) * compat_period_us;
 104:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   if ((exposure > compat_period_us) && (exposure < 0.95 * up_equiv_exposure))
 105:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   {
 106:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     /* Make exposure a multiple of the flickering period in case exposure is higher than the
 107:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****        flickering period and we are 5% under a multiple value */
 108:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *adjusted_exposure = (exposure / compat_period_us) * compat_period_us;
 109:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** 
 110:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     /* Increase the gain accordingly */
 111:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     compensation_gain = (float)exposure / (float)(*adjusted_exposure + 1);
 112:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     compensation_gain_mdb = (uint32_t)(20 * 1000 * log10(compensation_gain));
 113:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *adjusted_gain = gain + compensation_gain_mdb;
 114:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     if (*adjusted_gain > pSensorInfo->gain_max)
 115:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     {
 116:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****       *adjusted_gain = pSensorInfo->gain_max;
 117:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     }
 118:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   }
 119:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   else
 120:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   {
 121:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     /* Keep the initial values in case:
 122:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****        - We cannot update the exposure because the values are under the flickering period (will fli
 123:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****        - Or we are close to the upper multiple value (the acceptance criteria is set to 95% of the
 124:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****          multiple value to ensure no flickering effect will be visible) */
 125:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *adjusted_gain = gain;
 126:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****     *adjusted_exposure = exposure;
 127:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c ****   }
 128:../Middlewares/stm32-mw-camera/ISP_Library/isp/Src/isp_ae_algo.c **** }
