  98:../Middlewares/screenl/Src/scrl_usb.c **** static int cvt_uvcl_payload_format(SCRL_Format fmt)
  99:../Middlewares/screenl/Src/scrl_usb.c **** {
 100:../Middlewares/screenl/Src/scrl_usb.c ****   switch (fmt) {
 101:../Middlewares/screenl/Src/scrl_usb.c ****   case SCRL_RGB565:
 102:../Middlewares/screenl/Src/scrl_usb.c ****     return UVCL_PAYLOAD_FB_RGB565;
 103:../Middlewares/screenl/Src/scrl_usb.c ****   case SCRL_YUV422:
 104:../Middlewares/screenl/Src/scrl_usb.c ****     return UVCL_PAYLOAD_UNCOMPRESSED_YUY2;
 105:../Middlewares/screenl/Src/scrl_usb.c ****   default:
 106:../Middlewares/screenl/Src/scrl_usb.c ****     assert(0);
 107:../Middlewares/screenl/Src/scrl_usb.c ****   }
 108:../Middlewares/screenl/Src/scrl_usb.c **** 
 109:../Middlewares/screenl/Src/scrl_usb.c ****   return SCRL_RGB565;
 110:../Middlewares/screenl/Src/scrl_usb.c **** }
 111:../Middlewares/screenl/Src/scrl_usb.c **** 
 112:../Middlewares/screenl/Src/scrl_usb.c **** static int get_bpp(SCRL_Format fmt)
 113:../Middlewares/screenl/Src/scrl_usb.c **** {
 114:../Middlewares/screenl/Src/scrl_usb.c ****   switch (fmt) {
 115:../Middlewares/screenl/Src/scrl_usb.c ****   case SCRL_RGB565:
 116:../Middlewares/screenl/Src/scrl_usb.c ****     return 2;
 117:../Middlewares/screenl/Src/scrl_usb.c ****   case SCRL_ARGB4444:
 118:../Middlewares/screenl/Src/scrl_usb.c ****     return 2;
 119:../Middlewares/screenl/Src/scrl_usb.c ****   case SCRL_YUV422:
 120:../Middlewares/screenl/Src/scrl_usb.c ****     return 2;
 121:../Middlewares/screenl/Src/scrl_usb.c ****   case SCRL_BGR888:
 122:../Middlewares/screenl/Src/scrl_usb.c ****     return 3;
 123:../Middlewares/screenl/Src/scrl_usb.c ****   case SCRL_RGB888:
 124:../Middlewares/screenl/Src/scrl_usb.c ****     return 3;
 125:../Middlewares/screenl/Src/scrl_usb.c ****   default:
 126:../Middlewares/screenl/Src/scrl_usb.c ****     assert(0);
 127:../Middlewares/screenl/Src/scrl_usb.c ****   }
 128:../Middlewares/screenl/Src/scrl_usb.c **** 
 129:../Middlewares/screenl/Src/scrl_usb.c ****   return 2;
 130:../Middlewares/screenl/Src/scrl_usb.c **** }
 131:../Middlewares/screenl/Src/scrl_usb.c **** 
 132:../Middlewares/screenl/Src/scrl_usb.c **** static int get_screen_buffer_size(struct scrl_common_ctx *ctx)
 133:../Middlewares/screenl/Src/scrl_usb.c **** {
