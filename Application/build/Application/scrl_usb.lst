 138:../Middlewares/screenl/Src/scrl_usb.c **** {
 139:../Middlewares/screenl/Src/scrl_usb.c ****   uint8_t red, green, blue;
ARM GAS  /tmp/ccN2N8if.s 			page 4


 140:../Middlewares/screenl/Src/scrl_usb.c **** 
 141:../Middlewares/screenl/Src/scrl_usb.c ****   RGB_2_Y(r[0], g[0], b[0], y[0]);
 142:../Middlewares/screenl/Src/scrl_usb.c ****   RGB_2_Y(r[1], g[1], b[1], y[1]);
 143:../Middlewares/screenl/Src/scrl_usb.c **** 
