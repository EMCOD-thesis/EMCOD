 152:../Middlewares/screenl/Src/scrl_usb.c **** static void SCRU_cvt_rgb565_to_yuv422_internal(uint8_t *p_dst, uint8_t *p_src, int width, int heigh
 153:../Middlewares/screenl/Src/scrl_usb.c **** {
 154:../Middlewares/screenl/Src/scrl_usb.c ****   uint32_t *p_src_dual_rgb565 = (uint32_t *)p_src;
 155:../Middlewares/screenl/Src/scrl_usb.c ****   int32_t luma[2];
 156:../Middlewares/screenl/Src/scrl_usb.c ****   int32_t cb, cr;
 157:../Middlewares/screenl/Src/scrl_usb.c ****   uint8_t b[2];
 158:../Middlewares/screenl/Src/scrl_usb.c ****   uint8_t g[2];
 159:../Middlewares/screenl/Src/scrl_usb.c ****   uint8_t r[2];
 160:../Middlewares/screenl/Src/scrl_usb.c ****   int x, y;
 161:../Middlewares/screenl/Src/scrl_usb.c **** 
 162:../Middlewares/screenl/Src/scrl_usb.c ****   for (y = 0; y < height; y++)
 163:../Middlewares/screenl/Src/scrl_usb.c ****   {
 164:../Middlewares/screenl/Src/scrl_usb.c ****     for (x = 0; x < width; x += 2)
 165:../Middlewares/screenl/Src/scrl_usb.c ****     {
 166:../Middlewares/screenl/Src/scrl_usb.c ****       uint32_t p = p_src_dual_rgb565[x / 2];
 167:../Middlewares/screenl/Src/scrl_usb.c **** 
 168:../Middlewares/screenl/Src/scrl_usb.c ****       b[0] = (p >> 0) & 0x1f;
 169:../Middlewares/screenl/Src/scrl_usb.c ****       b[0] = (b[0] << 3) | (b[0] >> 2);
 170:../Middlewares/screenl/Src/scrl_usb.c ****       g[0] = (p >> 5) & 0x3f;
 171:../Middlewares/screenl/Src/scrl_usb.c ****       g[0] = (g[0] << 2) | (g[0] >> 4);
 172:../Middlewares/screenl/Src/scrl_usb.c ****       r[0] = (p >> 11) & 0x1f;
 173:../Middlewares/screenl/Src/scrl_usb.c ****       r[0] = (r[0] << 3) | (r[0] >> 2);
 174:../Middlewares/screenl/Src/scrl_usb.c ****       b[1] = (p >> 16) & 0x1f;
 175:../Middlewares/screenl/Src/scrl_usb.c ****       b[1] = (b[1] << 3) | (b[1] >> 2);
 176:../Middlewares/screenl/Src/scrl_usb.c ****       g[1] = (p >> 21) & 0x3f;
 177:../Middlewares/screenl/Src/scrl_usb.c ****       g[1] = (g[1] << 2) | (g[1] >> 4);
 178:../Middlewares/screenl/Src/scrl_usb.c ****       r[1] = (p >> 27) & 0x1f;
 179:../Middlewares/screenl/Src/scrl_usb.c ****       r[1] = (r[1] << 3) | (r[1] >> 2);
 180:../Middlewares/screenl/Src/scrl_usb.c **** 
 181:../Middlewares/screenl/Src/scrl_usb.c ****       SCRU_cvt_dual_pel_rgb_to_yuv(r, g, b, luma, &cb, &cr);
 182:../Middlewares/screenl/Src/scrl_usb.c ****       *p_dst++ = luma[0];
 183:../Middlewares/screenl/Src/scrl_usb.c ****       *p_dst++ = cb;
 184:../Middlewares/screenl/Src/scrl_usb.c ****       *p_dst++ = luma[1];
 185:../Middlewares/screenl/Src/scrl_usb.c ****       *p_dst++ = cr;
 186:../Middlewares/screenl/Src/scrl_usb.c ****     }
 187:../Middlewares/screenl/Src/scrl_usb.c ****     p_src_dual_rgb565 += width / 2;
 188:../Middlewares/screenl/Src/scrl_usb.c ****   }
 189:../Middlewares/screenl/Src/scrl_usb.c **** }
 190:../Middlewares/screenl/Src/scrl_usb.c **** 
 191:../Middlewares/screenl/Src/scrl_usb.c **** static void SCRU_cvt_rgb565_to_yuv422(struct scrl_common_ctx  *ctx_common)
 192:../Middlewares/screenl/Src/scrl_usb.c **** {
 193:../Middlewares/screenl/Src/scrl_usb.c ****   /* only convert layers area */
 194:../Middlewares/screenl/Src/scrl_usb.c ****   int stride = ctx_common->screen.size.width * 2;
 195:../Middlewares/screenl/Src/scrl_usb.c ****   int height = ctx_common->layers[0].size.height;
 196:../Middlewares/screenl/Src/scrl_usb.c ****   uint8_t *buffer = ctx_common->screen.address;
ARM GAS  /tmp/ccN2N8if.s 			page 5


 197:../Middlewares/screenl/Src/scrl_usb.c ****   int width = ctx_common->layers[0].size.width;
 198:../Middlewares/screenl/Src/scrl_usb.c ****   int y = ctx_common->layers[0].origin.y;
 199:../Middlewares/screenl/Src/scrl_usb.c ****   int x = ctx_common->layers[0].origin.x;
 200:../Middlewares/screenl/Src/scrl_usb.c ****   int r;
 201:../Middlewares/screenl/Src/scrl_usb.c **** 
 202:../Middlewares/screenl/Src/scrl_usb.c ****   buffer += y * stride + x * 2;
 203:../Middlewares/screenl/Src/scrl_usb.c **** 
 204:../Middlewares/screenl/Src/scrl_usb.c ****   for (r = 0; r < height; r++) {
 205:../Middlewares/screenl/Src/scrl_usb.c ****     SCRU_cvt_rgb565_to_yuv422_internal(buffer, buffer, width, 1);
 206:../Middlewares/screenl/Src/scrl_usb.c ****     buffer += stride;
 207:../Middlewares/screenl/Src/scrl_usb.c ****   }
 208:../Middlewares/screenl/Src/scrl_usb.c **** }
