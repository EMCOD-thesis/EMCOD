  42:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  43:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*  DESCRIPTION                                                           */
  44:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  45:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    This function searches a byte pool for a memory block to satisfy    */
  46:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    the requested number of bytes.  Merging of adjacent free blocks     */
  47:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    takes place during the search and a split of the block that         */
  48:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    satisfies the request may occur before this function returns.       */
  49:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  50:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    It is assumed that this function is called with interrupts enabled  */
  51:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    and with the tx_pool_owner field set to the thread performing the   */
  52:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    search.  Also note that the search can occur during allocation and  */
  53:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    release of a memory block.                                          */
  54:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  55:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*  INPUT                                                                 */
  56:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  57:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    pool_ptr                          Pointer to pool control block     */
  58:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    memory_size                       Number of bytes required          */
  59:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  60:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*  OUTPUT                                                                */
  61:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  62:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    UCHAR *                           Pointer to the allocated memory,  */
  63:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                        if successful.  Otherwise, a    */
  64:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                        NULL is returned                */
  65:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  66:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*  CALLS                                                                 */
  67:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*                                                                        */
  68:../Middlewares/threadx/common/src/tx_byte_pool_search.c **** /*    None                                                                */
