  28:../Middlewares/screenl/Src/scrl_common.c **** static uint32_t cvt_lcd_pixel_format(SCRL_Format fmt)
  29:../Middlewares/screenl/Src/scrl_common.c **** {
  30:../Middlewares/screenl/Src/scrl_common.c ****   switch (fmt) {
  31:../Middlewares/screenl/Src/scrl_common.c ****   case SCRL_RGB565:
  32:../Middlewares/screenl/Src/scrl_common.c ****     return LCD_PIXEL_FORMAT_RGB565;
  33:../Middlewares/screenl/Src/scrl_common.c ****   case SCRL_ARGB4444:
  34:../Middlewares/screenl/Src/scrl_common.c ****     return LCD_PIXEL_FORMAT_ARGB4444;
  35:../Middlewares/screenl/Src/scrl_common.c ****   case SCRL_BGR888:
  36:../Middlewares/screenl/Src/scrl_common.c ****     return LCD_PIXEL_FORMAT_RGB888;
  37:../Middlewares/screenl/Src/scrl_common.c ****   case SCRL_RGB888:
