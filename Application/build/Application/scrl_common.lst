  39:../Middlewares/screenl/Src/scrl_common.c ****   default:
  40:../Middlewares/screenl/Src/scrl_common.c ****     assert(0);
  41:../Middlewares/screenl/Src/scrl_common.c ****   }
  42:../Middlewares/screenl/Src/scrl_common.c **** 
  43:../Middlewares/screenl/Src/scrl_common.c ****   return LCD_PIXEL_FORMAT_RGB565;
  44:../Middlewares/screenl/Src/scrl_common.c **** }
