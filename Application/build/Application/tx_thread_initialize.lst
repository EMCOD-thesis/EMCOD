  95:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  96:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the 32-bit preempt priority bit maps.  There is one preempt bit map 
  97:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    for each 32 priority levels supported. If only 32 priorities are supported 
  98:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    there is only one bit map. Each set set bit corresponds to a preempted priority 
  99:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    level that had preemption-threshold active to protect against preemption of a 
 100:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    range of relatively higher priority threads.  */
 101:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 102:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_preempted_maps[TX_MAX_PRIORITIES/32];
 103:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 104:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 105:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the preempt map active bit map that specifies which of the previously 
 106:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    defined preempt maps have something set. This is only necessary if more than 
 107:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    32 priorities are supported.  */
 108:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 109:../Middlewares/threadx/common/src/tx_thread_initialize.c **** #if TX_MAX_PRIORITIES > 32
 110:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_preempted_map_active;
 111:../Middlewares/threadx/common/src/tx_thread_initialize.c **** #endif
 112:../Middlewares/threadx/common/src/tx_thread_initialize.c **** #endif
 113:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 114:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the variable that holds the highest priority group ready for 
 115:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    execution.  It is important to note that this is not necessarily the same
 116:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    as the priority of the thread pointed to by _tx_execute_thread.  */
 117:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 118:../Middlewares/threadx/common/src/tx_thread_initialize.c **** UINT            _tx_thread_highest_priority;
 119:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 120:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 121:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the array of thread pointers.  Each entry represents the threads that
 122:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    are ready at that priority group.  For example, index 10 in this array
 123:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    represents the first thread ready at priority 10.  If this entry is NULL,
 124:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    no threads are ready at that priority.  */
 125:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 126:../Middlewares/threadx/common/src/tx_thread_initialize.c **** TX_THREAD *     _tx_thread_priority_list[TX_MAX_PRIORITIES];
 127:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 128:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 129:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the global preempt disable variable.  If this is non-zero, preemption is
 130:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    disabled.  It is used internally by ThreadX to prevent preemption of a thread in 
 131:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    the middle of a service that is resuming or suspending another thread.  */
 132:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 133:../Middlewares/threadx/common/src/tx_thread_initialize.c **** volatile UINT   _tx_thread_preempt_disable;
