 207:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 208:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the total number of interrupt thread preemptions. Each time a thread is 
 209:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    preempted as a result of an ISR calling a ThreadX service, this variable is 
 210:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    incremented.  */
 211:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 212:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_performance_interrupt_preemption_count;
