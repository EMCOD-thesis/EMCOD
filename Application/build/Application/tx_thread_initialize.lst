  62:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  63:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the variable that holds the number of created threads. */
  64:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  65:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_created_count;
  66:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  67:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  68:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the current state variable.  When this value is 0, a thread
  69:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    is executing or the system is idle.  Other values indicate that 
  70:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    interrupt or initialization processing is active.  This variable is
  71:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    initialized to TX_INITIALIZE_IN_PROGRESS to indicate initialization is
  72:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    active.  */
  73:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  74:../Middlewares/threadx/common/src/tx_thread_initialize.c **** volatile ULONG  _tx_thread_system_state =  TX_INITIALIZE_IN_PROGRESS;
  75:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  76:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  77:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the 32-bit priority bit-maps. There is one priority bit map for each
  78:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    32 priority levels supported. If only 32 priorities are supported there is 
  79:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    only one bit map. Each bit within a priority bit map represents that one 
  80:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    or more threads at the associated thread priority are ready.  */
  81:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  82:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_priority_maps[TX_MAX_PRIORITIES/32];
