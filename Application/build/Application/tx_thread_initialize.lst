  38:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the pointer that contains the system stack pointer.  This is
  39:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    utilized when control returns from a thread to the system to reset the
  40:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    current stack.  This is setup in the low-level initialization function. */
  41:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  42:../Middlewares/threadx/common/src/tx_thread_initialize.c **** VOID *          _tx_thread_system_stack_ptr;
  43:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  44:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  45:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the current thread pointer.  This variable points to the currently
  46:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    executing thread.  If this variable is NULL, no thread is executing.  */
  47:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  48:../Middlewares/threadx/common/src/tx_thread_initialize.c **** TX_THREAD *     _tx_thread_current_ptr;
