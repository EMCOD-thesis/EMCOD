 135:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 136:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the global function pointer for mutex cleanup on thread completion or 
 137:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    termination. This pointer is setup during mutex initialization.  */
 138:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 139:../Middlewares/threadx/common/src/tx_thread_initialize.c **** VOID            (*_tx_thread_mutex_release)(TX_THREAD *thread_ptr);
