  50:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  51:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the variable that holds the next thread to execute.  It is important
  52:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    to remember that this is not necessarily equal to the current thread 
  53:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    pointer.  */
  54:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  55:../Middlewares/threadx/common/src/tx_thread_initialize.c **** TX_THREAD *     _tx_thread_execute_ptr;
  56:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  57:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  58:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the head pointer of the created thread list.  */
  59:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
  60:../Middlewares/threadx/common/src/tx_thread_initialize.c **** TX_THREAD *     _tx_thread_created_ptr;
