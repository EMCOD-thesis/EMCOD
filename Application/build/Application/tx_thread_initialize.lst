 156:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     23                  TX_TIMER_PROCESS_IN_ISR defined
 157:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     22                  TX_REACTIVATE_INLINE defined
 158:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     21                  TX_DISABLE_STACK_FILLING defined
 159:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     20                  TX_ENABLE_STACK_CHECKING defined
 160:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     19                  TX_DISABLE_PREEMPTION_THRESHOLD defined
 161:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     18                  TX_DISABLE_REDUNDANT_CLEARING defined
 162:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     17                  TX_DISABLE_NOTIFY_CALLBACKS defined
 163:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     16                  TX_BLOCK_POOL_ENABLE_PERFORMANCE_INFO defined
 164:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     15                  TX_BYTE_POOL_ENABLE_PERFORMANCE_INFO defined
 165:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     14                  TX_EVENT_FLAGS_ENABLE_PERFORMANCE_INFO defined
 166:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     13                  TX_MUTEX_ENABLE_PERFORMANCE_INFO defined
 167:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     12                  TX_QUEUE_ENABLE_PERFORMANCE_INFO defined
 168:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     11                  TX_SEMAPHORE_ENABLE_PERFORMANCE_INFO defined
 169:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     10                  TX_THREAD_ENABLE_PERFORMANCE_INFO defined
 170:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     9                   TX_TIMER_ENABLE_PERFORMANCE_INFO defined
 171:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     8                   TX_ENABLE_EVENT_TRACE defined
 172:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     7                   TX_ENABLE_EXECUTION_CHANGE_NOTIFY defined
 173:../Middlewares/threadx/common/src/tx_thread_initialize.c ****                     6-0                 Port Specific   */
 174:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
