 220:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 221:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the total number of time-slices.  Each time a time-slice operation is 
 222:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    actually performed (another thread is setup for running) this variable is 
 223:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    incremented.  */
 224:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 225:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_performance_time_slice_count;
 226:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 227:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 228:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the total number of thread relinquish operations.  Each time a thread 
