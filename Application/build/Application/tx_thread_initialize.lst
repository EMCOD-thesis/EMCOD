 196:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the total number of thread suspensions. Each time a thread enters a 
ARM GAS  /tmp/cc1rVKuD.s 			page 5


 197:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    suspended state this variable is incremented.  */
 198:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 199:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_performance_suspend_count;
 200:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 201:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 202:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the total number of solicited thread preemptions. Each time a thread is 
 203:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    preempted by directly calling a ThreadX service, this variable is incremented.  */
 204:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 205:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_performance_solicited_preemption_count;
