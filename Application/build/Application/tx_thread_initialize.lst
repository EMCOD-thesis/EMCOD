 214:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 215:../Middlewares/threadx/common/src/tx_thread_initialize.c **** /* Define the total number of priority inversions. Each time a thread is blocked by
 216:../Middlewares/threadx/common/src/tx_thread_initialize.c ****    a mutex owned by a lower-priority thread, this variable is incremented.  */
 217:../Middlewares/threadx/common/src/tx_thread_initialize.c **** 
 218:../Middlewares/threadx/common/src/tx_thread_initialize.c **** ULONG           _tx_thread_performance_priority_inversion_count;
