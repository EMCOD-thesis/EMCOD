 210:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** 
 211:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #define TX_TRACE_TIME_SOURCE                    *((volatile ULONG *) 0x0a800024)
 212:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** #define TX_TRACE_TIME_MASK                      0x0000FFFFUL
 213:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** 
 214:../Middlewares/threadx/ports/cortex_m55/gnu/inc/tx_port.h **** */
