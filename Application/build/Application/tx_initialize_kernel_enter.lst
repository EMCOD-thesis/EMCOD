  58:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*                                                                        */
  59:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    This function is the first ThreadX function called during           */
  60:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    initialization.  It is called from the application's "main()"       */
  61:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    function.  It is important to note that this routine never          */
  62:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    returns.  The processing of this function is relatively simple:     */
  63:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    it calls several ThreadX initialization functions (if needed),      */
  64:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    calls the application define function, and then invokes the         */
  65:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    scheduler.                                                          */
  66:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*                                                                        */
  67:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*  INPUT                                                                 */
  68:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*                                                                        */
  69:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    None                                                                */
  70:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*                                                                        */
  71:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*  OUTPUT                                                                */
  72:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*                                                                        */
  73:../Middlewares/threadx/common/src/tx_initialize_kernel_enter.c **** /*    None                                                                */
