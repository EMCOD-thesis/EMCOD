  40:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c **** void construct_patch_id_streng(char *patch_id, int streng_idx, bool lsb_msb)
  41:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c **** {
  42:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[0] = 'S';
  43:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[1] = 'E';
  44:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[2] = '_';
  45:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[3] = '0' + (streng_idx / 10);
  46:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[4] = '0' + (streng_idx % 10);
  47:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[5] = '_';
  48:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[6] = (lsb_msb ? 'L' : 'M');
  49:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[7] = 'S';
  50:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[8] = 'B';
  51:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c ****   patch_id[9] = '\0';
  52:../Middlewares/stedgeai-lib/Npu/ll_aton/ll_aton_cipher.c **** }
