 102:../STM32Cube_FW_N6/Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_usb.c ****   {
 103:../STM32Cube_FW_N6/Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_usb.c ****     /* make sure to reserve 18 fifo Locations for DMA buffers */
 104:../STM32Cube_FW_N6/Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_usb.c ****     USBx->GDFIFOCFG &= ~(0xFFFFUL << 16);
