  41:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*  DESCRIPTION                                                           */
  42:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */ 
  43:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    This function checks if a NULL-terminated C string reaches its end  */ 
  44:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    before specified length exceeds.                                    */ 
  45:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */ 
  46:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    On success the actual length of C string is written back to UINT    */ 
  47:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    variable pointed by string_length_ptr (if not NULL).                */ 
  48:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    Otherwise the variable keeps untouched.                             */ 
  49:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */
  50:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    Note NULL terminator is not counted in string length                */
  51:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    (same as C strlen).                                                 */
  52:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */ 
  53:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*  INPUT                                                                 */ 
  54:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */ 
  55:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    string                                Pointer to string             */ 
  56:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    string_length_ptr                     Pointer to UINT to receive    */ 
  57:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                            the string length           */ 
  58:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    max_string_length                     Max string length             */ 
  59:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */ 
  60:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*  OUTPUT                                                                */ 
  61:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */ 
  62:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    returns success if the string length was less than the max length,  */ 
  63:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*    else it returns error                                               */ 
  64:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_length_check.c **** /*                                                                        */ 
