  43:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    This function converts a ascii string to a unicode string.          */ 
  44:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*                                                                        */
  45:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    Note:                                                               */
  46:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    The unicode string length (including NULL-terminator) is limited by */
  47:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    length in a byte, so max ascii string length must be no more than   */
  48:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    254 (NULL-terminator excluded). Only first 254 characters           */
  49:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    are converted if the string is too long.                            */
  50:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    The buffer of destination must have enough space for result, at     */
  51:../STM32Cube_FW_N6/Middlewares/ST/usbx/common/core/src/ux_utility_string_to_unicode.c **** /*    least 1 + (strlen(source) + 1) * 2 bytes.                           */
